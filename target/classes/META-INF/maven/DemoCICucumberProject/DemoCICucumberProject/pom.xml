<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>DemoCICucumberProject</groupId>
  <artifactId>DemoCICucumberProject</artifactId>
  <version>0.0.1-SNAPSHOT</version>
  
  
   <!--GLOBAL PROPERTIES-->
   <properties>
    <selenium.version>4.27.0</selenium.version>
    <cucumber.version>7.30.0</cucumber.version>
    <cucumber.testng.version>7.30.0</cucumber.testng.version>
    <cucumber.java.version>7.30.0</cucumber.java.version>
    <maven.compiler.source>17</maven.compiler.source>
    <maven.compiler.target>17</maven.compiler.target>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.plugin.version>3.11.0</maven.compiler.plugin.version>
    <surefire.plugin.version>3.2.5</surefire.plugin.version>
   </properties>
   
   
    <build>
        <plugins>
            <!-- Compiler plugin for Java 17 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <source>17</source>
                    <target>17</target>
                </configuration>
            </plugin>

            <!-- Surefire plugin for TestNG -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.5</version>
                <configuration>
                 <!-- Pass system properties -->
                    <systemPropertyVariables>
                        <env>${env}</env>
                        <browser>${browser}</browser>
                        <cucumber.filter.tags>${tags}</cucumber.filter.tags>
                    </systemPropertyVariables>
                </configuration>
            </plugin>
        </plugins>
    </build>

   <profiles>
    <profile>
            <id>qa</id>
            <properties>
                <env>qa</env>
                <browser>chrome</browser>
                <tags>@smoke</tags>
            </properties>
        </profile>

        <profile>
            <id>uat</id>
            <properties>
                <env>uat</env>
                <browser>firefox</browser>
                <tags>@regression</tags>
            </properties>
        </profile>
   
   </profiles>

